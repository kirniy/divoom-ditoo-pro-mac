#!/usr/bin/env bash

set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SESSION_NAME="${1:-divoom-ralph-merge}"
TMUX_BIN="${TMUX_BIN:-$(command -v tmux || echo /opt/homebrew/bin/tmux)}"
TMUX_SOCKET="${TMUX_SOCKET:-$ROOT/.cache/tmux/divoom-ralph-merge.sock}"

echo "Session: $SESSION_NAME"
if "$TMUX_BIN" -S "$TMUX_SOCKET" has-session -t "$SESSION_NAME" 2>/dev/null; then
    echo "tmux: running"
    echo
    "$TMUX_BIN" -S "$TMUX_SOCKET" capture-pane -p -t "$SESSION_NAME" -S -40 || true
else
    echo "tmux: not running"
fi

echo
echo "Status file:"
if [[ -f "$ROOT/.ralph-merge/status.json" ]]; then
    cat "$ROOT/.ralph-merge/status.json"
else
    echo "missing"
fi
