#!/bin/zsh
set -euo pipefail

ROOT="/Users/kirniy/dev/divoom"
APP="$ROOT/build/DivoomMenuBar.app"
BIN_DIR="$APP/Contents/MacOS"

mkdir -p "$BIN_DIR"
cp "$ROOT/macos/DivoomMenuBar/Info.plist" "$APP/Contents/Info.plist"

/usr/bin/swiftc \
  -O \
  -parse-as-library \
  -framework AppKit \
  -framework CoreBluetooth \
  -framework IOBluetooth \
  "$ROOT/macos/DivoomMenuBar/BluetoothSupport.swift" \
  "$ROOT/macos/DivoomMenuBar/main.swift" \
  -o "$BIN_DIR/DivoomMenuBar"

/usr/bin/codesign --force --sign - "$APP" >/dev/null 2>&1 || true

printf '%s\n' "$APP"
